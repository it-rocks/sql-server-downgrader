<Window x:Class="SqlServerDowngrader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SQL Server Database Downgrader" Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#FFFFFF" Foreground="#333333">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Background="#2E75B6" VerticalAlignment="Center" Padding="20,0">
            <TextBlock Text="SQL Server Database Downgrader" 
                       FontSize="24" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="Migrate databases to lower SQL Server versions" 
                       FontSize="12" Foreground="#E0E0E0"/>
        </StackPanel>

        <!-- Tabs -->
        <TabControl Grid.Row="1" Margin="10" Style="{StaticResource TabControlStyle}">
            
            <!-- Tab 1: Source Database -->
            <TabItem Header="1. Source Database" Padding="15,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="Select Source Instance" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="SourceInstanceCombo" Grid.Column="0" Height="35" Padding="10"/>
                            <Button Content="🔄 Refresh" Grid.Column="1" Margin="10,0,0,0" Height="35" 
                                    Style="{StaticResource ButtonStyle}" Click="RefreshInstances_Click"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,0,0,15">
                        <TextBlock Text="Service Status" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
                        <TextBlock x:Name="SourceServiceStatus" Text="Checking..." Foreground="#666666"/>
                        <Button x:Name="StartServiceBtn" Content="▶ Start Service" Height="30" Margin="0,10,0,0"
                                Style="{StaticResource ButtonStyle}" Click="StartService_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,0,0,15">
                        <TextBlock Text="Select Source Database" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <ComboBox x:Name="SourceDatabaseCombo" Height="35" Padding="10"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,0,0,15">
                        <TextBlock Text="Database Info" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
                        <TextBlock x:Name="SourceDatabaseInfo" Text="No database selected" Foreground="#666666"/>
                    </StackPanel>

                    <TextBlock Grid.Row="4" Text="Database details will appear here" 
                              VerticalAlignment="Bottom" Foreground="#999999" FontStyle="Italic"/>
                </Grid>
            </TabItem>

            <!-- Tab 2: Target Database -->
            <TabItem Header="2. Target Database" Padding="15,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="Select Target Instance" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <ComboBox x:Name="TargetInstanceCombo" Height="35" Padding="10"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,0,0,15">
                        <TextBlock Text="Target Database (Leave empty to auto-create)" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <ComboBox x:Name="TargetDatabaseCombo" Height="35" Padding="10" IsEditable="True"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,0,0,15">
                        <CheckBox x:Name="OverwriteCheckbox" Content="Overwrite target database if it exists" Margin="0,10,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3">
                        <TextBlock Text="Target Configuration" FontWeight="Bold" FontSize="12" Margin="0,0,0,10"/>
                        <TextBlock x:Name="TargetInfo" Text="No target selected" Foreground="#666666" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Tab 3: Conversion Options -->
            <TabItem Header="3. Options" Padding="15,10">
                <ScrollViewer>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Conversion Mode -->
                        <GroupBox Grid.Row="0" Header="Conversion Mode" Margin="0,0,0,15" Padding="15">
                            <StackPanel>
                                <RadioButton x:Name="StructureOnlyRadio" Content="Structure Only (No Data)" GroupName="ConversionMode" IsChecked="True" Margin="0,5,0,5"/>
                                <RadioButton x:Name="StructureAndDataRadio" Content="Structure + Data" GroupName="ConversionMode" Margin="0,5,0,5"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Test Mode -->
                        <GroupBox Grid.Row="1" Header="Test Mode" Margin="0,0,0,15" Padding="15">
                            <StackPanel>
                                <CheckBox x:Name="TestModeCheckbox" Content="Enable Test Run (Dry-run without actual conversion)" Margin="0,5,0,0"/>
                                <TextBlock Text="A test run will validate all conversion steps without modifying the target database." 
                                          Foreground="#666666" FontSize="11" Margin="20,5,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Advanced Options -->
                        <GroupBox Grid.Row="2" Header="Advanced Options" Margin="0,0,0,15" Padding="15">
                            <StackPanel>
                                <CheckBox x:Name="IncludeIndexesCheckbox" Content="Include Indexes" IsChecked="True" Margin="0,5,0,5"/>
                                <CheckBox x:Name="IncludeConstraintsCheckbox" Content="Include Constraints" IsChecked="True" Margin="0,5,0,5"/>
                                <CheckBox x:Name="IncludeTriggersCheckbox" Content="Include Triggers" IsChecked="True" Margin="0,5,0,5"/>
                                <CheckBox x:Name="IncludeSPCheckbox" Content="Include Stored Procedures" IsChecked="True" Margin="0,5,0,5"/>
                                <CheckBox x:Name="PreserveIdentityCheckbox" Content="Preserve Identity Values" IsChecked="True" Margin="0,5,0,0"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Export Options -->
                        <GroupBox Grid.Row="3" Header="Export Options" Margin="0,0,0,15" Padding="15">
                            <StackPanel>
                                <CheckBox x:Name="ExportScriptCheckbox" Content="Export SQL Script to File" Margin="0,5,0,0"/>
                                <Grid Margin="20,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="ExportPathTextbox" Grid.Column="0" Height="30" Padding="10" IsEnabled="False"/>
                                    <Button Content="Browse" Grid.Column="1" Margin="10,0,0,0" Height="30" 
                                            Style="{StaticResource ButtonStyle}" Click="Browse_Click"/>
                                </Grid>
                            </StackPanel>
                        </GroupBox>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 4: Progress & Logging -->
            <TabItem Header="4. Progress" Padding="15,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ProgressBar x:Name="ConversionProgress" Grid.Row="0" Height="30" Margin="0,0,0,10" Value="0" Maximum="100"/>
                    
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Status: " FontWeight="Bold"/>
                        <TextBlock x:Name="StatusText" Text="Ready" Foreground="#4CAF50"/>
                    </StackPanel>

                    <TextBox x:Name="LogTextbox" Grid.Row="2" Margin="0,0,0,10" 
                            VerticalScrollBarVisibility="Auto" Background="#F5F5F5" Padding="10"
                            IsReadOnly="True" FontFamily="Courier New" FontSize="11"/>

                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="💾 Save Log" Grid.Column="1" Height="35" Margin="0,0,10,0" 
                                Style="{StaticResource ButtonStyle}" Click="SaveLog_Click"/>
                        <Button Content="🔄 Reset" Grid.Column="2" Height="35" Margin="0,0,10,0"
                                Style="{StaticResource ButtonStyle}" Click="Reset_Click"/>
                        <Button Content="▶ Start Conversion" Grid.Column="3" Height="35" 
                                Style="{StaticResource ButtonStyle}" Click="StartConversion_Click"/>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <StatusBar Grid.Row="2" Background="#F0F0F0" Padding="20,0">
            <TextBlock x:Name="FooterText" Text="Ready" Foreground="#666666"/>
        </StatusBar>
    </Grid>
</Window>